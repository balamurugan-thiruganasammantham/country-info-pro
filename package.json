{
  "name": "country-info-pro",
  "version": "1.3.0",
  "description": "Comprehensive country data for 250 countries with fuzzy search, ISO codes, country groupings (EU, NATO, G7, BRICS, ASEAN), timezone/driving side filters, distance calculator, postal code validation - zero dependencies, full TypeScript",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "country",
    "countries",
    "iso",
    "iso-3166",
    "alpha-2",
    "alpha-3",
    "currency",
    "timezone",
    "flag",
    "phone-code",
    "calling-code",
    "country-info",
    "country-data",
    "country-lookup",
    "country-search",
    "fuzzy-search",
    "country-code",
    "capital",
    "population",
    "country-flags",
    "eu",
    "nato",
    "g7",
    "g20",
    "brics",
    "asean",
    "country-groupings",
    "postal-code",
    "driving-side",
    "distance-calculator",
    "geolocation",
    "typescript"
  ],
  "author": "Balamurugan <infobalamurugan22@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/balamurugan-thiruganasammantham/country-info-pro.git"
  },
  "bugs": {
    "url": "https://github.com/balamurugan-thiruganasammantham/country-info-pro/issues"
  },
  "homepage": "https://github.com/balamurugan-thiruganasammantham/country-info-pro#readme",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "fetch-data": "tsx scripts/fetch-data.ts",
    "bench": "tsx scripts/benchmark.ts",
    "prepublishOnly": "npm run build && npm run test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "tsx": "^4.0.0"
  }
}
